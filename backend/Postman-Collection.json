{
  "info": {
    "name": "Control de Acceso CIDE - API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
      }
    },
    {
      "name": "Login Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\"\n}" },
        "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
      }
    },
    {
      "name": "Login Guarda",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"guarda\",\n  \"password\": \"Guarda123!\"\n}" },
        "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
      }
    },
    {
      "name": "Primer ingreso",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{guarda_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"documento\": \"102030405\",\n  \"qr_uid\": \"QR12345\",\n  \"nombre\": \"Luis Ramon\",\n  \"carrera\": \"Ingenieria Mecatronica\",\n  \"vigencia\": true,\n  \"placa\": \"ABC-123\",\n  \"color\": \"Negro\"\n}" },
        "url": { "raw": "{{base_url}}/estudiantes/primer-ingreso", "host": ["{{base_url}}"], "path": ["estudiantes", "primer-ingreso"] }
      }
    },
    {
      "name": "Registrar movimiento",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{guarda_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"qr_uid\": \"QR12345\"\n}" },
        "url": { "raw": "{{base_url}}/movimientos/registrar", "host": ["{{base_url}}"], "path": ["movimientos", "registrar"] }
      }
    },
    {
      "name": "Listar movimientos",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
        "url": { "raw": "{{base_url}}/movimientos", "host": ["{{base_url}}"], "path": ["movimientos"] }
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "guarda_token", "value": "", "type": "string" }
  ]
}
